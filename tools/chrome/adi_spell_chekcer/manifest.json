{
  "manifest_version": 3,
  "name": "adi spell chekcer",
  "version": "1.0.0",
  "description": "Fix All spelling in the focused text field via the free LanguageTool API.",
  "permissions": [],
  "host_permissions": ["https://api.languagetool.org/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "adi spell chekcer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
