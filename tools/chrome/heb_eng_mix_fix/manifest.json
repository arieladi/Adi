{
  "manifest_version": 3,
  "name": "HEB ENG MIX FIX",
  "version": "3.1.0",
  "description": "Fixes wrong-keyboard-layout typing both ways (EN↔HE), live — plus idle spell-check with per-word fixes via Google Suggest.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://suggestqueries.google.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HEB ENG MIX FIX",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "english_dict.js",
        "hebrew_dict.js",
        "hebrew_map.js",
        "ui.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
